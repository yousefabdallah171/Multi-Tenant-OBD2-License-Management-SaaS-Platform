{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["src/*"],
      "react-router-dom": ["node_modules/react-router-dom"],
      "sonner": ["node_modules/sonner"],
      "axios": ["node_modules/axios"],
      "zustand": ["node_modules/zustand"],
      "zustand/*": ["node_modules/zustand/*"],
      "class-variance-authority": ["node_modules/class-variance-authority"],
      "clsx": ["node_modules/clsx"],
      "tailwind-merge": ["node_modules/tailwind-merge"],
      "i18next": ["node_modules/i18next"],
      "react-i18next": ["node_modules/react-i18next"]
    }
  },
  "include": [
    "./setupTests.ts",
    "./tests/**/*.ts",
    "./tests/**/*.tsx",
    "../frontend/src/**/*.ts",
    "../frontend/src/**/*.tsx"
  ],
  "exclude": [
    "./cypress/**/*",
    "../frontend/node_modules",
    "../frontend/dist"
  ]
}
